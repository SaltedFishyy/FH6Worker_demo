page {
  background: #0fae96;
  box-sizing: border-box;
}

view,
text,
input,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
}

button::after {
  border: none;
}

.page-bg {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  display: block;
  z-index: 0;
  pointer-events: none;
}

.page-layer {
  position: relative;
  z-index: 1;
}

.custom-nav {
  height: 150rpx;
  margin: -28rpx -28rpx 24rpx;
  padding: 80rpx 180rpx 20rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  color: #ffffff;
  background: transparent;
  border-bottom: 0;
  box-shadow: none;
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.custom-nav-title {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 26rpx;
  line-height: 1.25;
  font-weight: 700;
  text-align: center;
  text-shadow: 0 3rpx 10rpx rgba(3, 77, 67, 0.24);
}

/* Glass neon refresh */
.custom-nav {
  background: transparent;
  border-bottom: 0;
  box-shadow: none;
  -webkit-backdrop-filter: none;
  backdrop-filter: none;
}

.custom-nav-title {
  max-width: 360rpx;
  color: rgba(255, 255, 255, 0.96);
  font-weight: 800;
  text-shadow:
    0 2rpx 8rpx rgba(3, 35, 31, 0.42),
    0 0 12rpx rgba(223, 254, 247, 0.18);
}
