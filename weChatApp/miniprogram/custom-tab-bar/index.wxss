.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding: 6rpx 0 env(safe-area-inset-bottom);
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  background: linear-gradient(180deg, rgba(7, 94, 84, 0) 0%, rgba(7, 94, 84, 0.58) 22%, rgba(7, 94, 84, 0.68) 100%);
  border-top: 0;
  box-sizing: border-box;
  box-shadow: none;
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
}

.tabbar-item {
  min-width: 0;
  height: 88rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 5rpx;
  margin: 0 8rpx;
  border: 1rpx solid transparent;
  border-radius: 14rpx;
  background: rgba(223, 254, 247, 0.05);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.tabbar-item-active {
  background: rgba(191, 255, 0, 0.16);
  border-color: rgba(191, 255, 0, 0.34);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.24), 0 8rpx 18rpx rgba(4, 62, 55, 0.12);
}

.tabbar-icon {
  width: 44rpx;
  height: 44rpx;
  display: block;
}

.tabbar-text {
  color: #dffef7;
  font-size: 22rpx;
  line-height: 1.15;
  font-weight: 700;
  text-align: center;
}

.tabbar-text-active {
  color: #bfff00;
}

/* Glass neon visual refresh */
.tabbar {
  background: linear-gradient(180deg, rgba(4, 54, 49, 0) 0%, rgba(4, 54, 49, 0.52) 22%, rgba(4, 54, 49, 0.66) 100%);
  border-top: 0;
  box-shadow: none;
}

.tabbar-item {
  background: rgba(223, 254, 247, 0.08);
  border-color: rgba(223, 254, 247, 0.12);
}

.tabbar-item-active {
  background: rgba(191, 255, 0, 0.16);
  border-color: rgba(191, 255, 0, 0.36);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2),
    0 0 18rpx rgba(191, 255, 0, 0.12);
}
