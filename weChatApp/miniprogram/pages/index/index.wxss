/* Unified dark card style */
.recommend-entry,
.upgrade-entry,
.quota,
.section,
.result-group {
  border-radius: 16rpx;
  border: 1rpx solid rgba(191, 255, 0, 0.32);
  background:
    linear-gradient(135deg, rgba(11, 79, 70, 0.7) 0%, rgba(4, 36, 34, 0.82) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(223, 254, 247, 0.18),
    inset 0 0 34rpx rgba(191, 255, 0, 0.05),
    0 0 0 1rpx rgba(223, 254, 247, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.24),
    0 0 20rpx rgba(191, 255, 0, 0.12);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.recommend-entry,
.upgrade-entry {
  min-height: 82rpx;
}

.recommend-entry-title,
.upgrade-entry-title,
.quota,
.section-title,
.label,
.input,
.select-value {
  color: rgba(234, 255, 251, 0.94);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.24);
}

.section {
  padding: 22rpx;
}

.section::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16rpx;
  bottom: 16rpx;
  width: 3rpx;
  background: rgba(191, 255, 0, 0.84);
  box-shadow: 0 0 16rpx rgba(191, 255, 0, 0.8);
}

.section::after {
  opacity: 0.46;
}

.section-title {
  padding-left: 18rpx;
  color: #ffffff;
  font-size: 31rpx;
}

.section-title::before {
  width: 0;
  box-shadow: none;
}

.section-title-icon,
.field-icon {
  filter: brightness(0) saturate(100%) invert(88%) sepia(91%) saturate(733%) hue-rotate(25deg) brightness(104%) contrast(103%);
}

.field,
.toggle-row {
  min-height: 76rpx;
  padding: 0 16rpx;
  border-top: 1rpx solid rgba(223, 254, 247, 0.12);
  background: rgba(2, 30, 28, 0.2);
}

.field:first-of-type,
.toggle-row:first-of-type {
  border-top: 1rpx solid rgba(223, 254, 247, 0.1);
}

.label {
  color: rgba(234, 255, 251, 0.9);
}

.input {
  color: #ffffff;
  font-weight: 800;
}

.select-value {
  color: #ffffff;
  font-weight: 800;
}

.picker .select-value::after {
  color: rgba(191, 255, 0, 0.82);
}

.tire-part,
.edit-input {
