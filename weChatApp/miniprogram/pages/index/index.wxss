/* Preference feedback v1.2 */
.preference-panel {
  max-height: 86vh;
  padding: 30rpx 30rpx calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  background:
    linear-gradient(180deg, rgba(235, 255, 249, 0.84), rgba(221, 245, 239, 0.78));
}

.preference-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding-bottom: 18rpx;
}

.preference-title {
  color: #063b35;
  font-size: 34rpx;
  font-weight: 900;
}

.preference-subtitle {
  margin-top: 8rpx;
  color: rgba(6, 59, 53, 0.66);
  font-size: 22rpx;
  line-height: 1.35;
}

.preference-version {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #073b35;
  background: rgba(191, 255, 0, 0.78);
  border: 1rpx solid rgba(233, 255, 155, 0.82);
  font-size: 22rpx;
  font-weight: 900;
}

.preference-scroll {
  min-height: 0;
  max-height: calc(86vh - 190rpx - env(safe-area-inset-bottom));
}

.preference-section {
  margin-bottom: 18rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.2),
    0 10rpx 24rpx rgba(0, 0, 0, 0.12);
}

.preference-section-light {
  background: rgba(235, 255, 249, 0.62);
  border-color: rgba(255, 255, 255, 0.58);
}

.preference-section-dark {
  background:
    radial-gradient(circle at 88% 0%, rgba(191, 255, 0, 0.14), transparent 36%),
    linear-gradient(135deg, rgba(6, 65, 58, 0.84), rgba(3, 42, 38, 0.8));
  border-color: rgba(191, 255, 0, 0.34);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.14),
    0 0 24rpx rgba(191, 255, 0, 0.08),
    0 12rpx 28rpx rgba(0, 0, 0, 0.18);
}

.preference-section-title {
  position: relative;
  min-height: 50rpx;
  padding: 10rpx 18rpx 10rpx 28rpx;
  border-radius: 16rpx;
  color: #073b35;
  background: linear-gradient(135deg, rgba(191, 255, 0, 0.9), rgba(218, 255, 99, 0.9));
  font-size: 28rpx;
  font-weight: 900;
}

.preference-section-dark .preference-section-title {
  color: #ffffff;
  background:
    linear-gradient(90deg, rgba(191, 255, 0, 0.22), rgba(255, 255, 255, 0.08) 54%, rgba(255, 255, 255, 0.02));
  border: 1rpx solid rgba(191, 255, 0, 0.26);
}

.preference-section-dark .preference-section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 10rpx;
  bottom: 10rpx;
  width: 5rpx;
  border-radius: 999rpx;
  background: rgba(191, 255, 0, 0.92);
  box-shadow: 0 0 16rpx rgba(191, 255, 0, 0.54);
}

.preference-section .preference-row {
  margin-top: 18rpx;
}

.preference-section-light .preference-label {
  color: #064e3b;
}

.preference-section-dark .preference-label {
  color: rgba(234, 255, 251, 0.94);
}

.preference-section-dark .scale-row {
  color: rgba(223, 254, 247, 0.68);
}

.preference-helper {
  margin: 16rpx 4rpx 0;
  color: rgba(223, 254, 247, 0.72);
  font-size: 22rpx;
  line-height: 1.45;
}

.empty-feedback {
  color: rgba(223, 254, 247, 0.58);
}

.feedback-chip-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 16rpx;
}

.feedback-chip {
  min-height: 70rpx;
  padding: 0 18rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: rgba(234, 255, 251, 0.92);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.04));
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  font-size: 24rpx;
  font-weight: 900;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.16),
    0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}

.feedback-chip.active {
  color: #073b35;
  background: linear-gradient(135deg, rgba(191, 255, 0, 0.92), rgba(218, 255, 99, 0.92));
  border-color: rgba(233, 255, 155, 0.92);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
    0 8rpx 20rpx rgba(191, 255, 0, 0.2);
}

.strength-section {
  margin-bottom: 0;
}

/* Entry cards: semantic icon + consistent action sizing */
.entry-main {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.entry-icon {
  flex: 0 0 auto;
  width: 42rpx;
  height: 42rpx;
  display: block;
  opacity: 0.96;
  filter: drop-shadow(0 0 8rpx rgba(191, 255, 0, 0.36));
}

.recommend-entry-title,
.upgrade-entry-title {
  white-space: nowrap;
}

.recommend-entry-action,
.upgrade-entry-action {
  width: 196rpx;
  min-width: 196rpx;
  padding: 0 10rpx;
}

/* Preference panel polish: keep all setting cards in one light glass system. */
.preference-panel {
  box-sizing: border-box;
  overflow: hidden;
  max-height: 86vh;
  padding: 30rpx 30rpx calc(24rpx + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(235, 255, 249, 0.88), rgba(214, 238, 232, 0.82));
}

.preference-scroll {
  flex: 1 1 auto;
  min-height: 0;
  height: calc(86vh - 250rpx - env(safe-area-inset-bottom));
  max-height: none;
  padding-bottom: 26rpx;
  box-sizing: border-box;
}

.preference-section,
.preference-section-light,
.preference-section-dark,
.strength-section {
  background:
    radial-gradient(circle at 92% 0%, rgba(191, 255, 0, 0.16), transparent 34%),
    linear-gradient(135deg, rgba(239, 255, 251, 0.72), rgba(218, 240, 235, 0.62));
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.58),
    0 10rpx 22rpx rgba(4, 50, 44, 0.12);
}

.preference-section-dark .preference-section-title,
.preference-section-title {
  color: #073b35;
  background: linear-gradient(135deg, rgba(191, 255, 0, 0.9), rgba(218, 255, 99, 0.9));
  border: 0;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
    0 6rpx 14rpx rgba(111, 199, 0, 0.1);
}

.preference-section-dark .preference-section-title::before {
  display: none;
}

.preference-section-light .preference-label,
.preference-section-dark .preference-label,
.preference-label {
  color: #064e3b;
}

.preference-section-dark .scale-row,
.scale-row {
  color: rgba(7, 94, 84, 0.72);
}

.preference-helper,
.empty-feedback {
  color: rgba(6, 78, 59, 0.72);
}

.feedback-chip {
  color: #064e3b;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.18));
  border-color: rgba(6, 78, 59, 0.18);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
    0 8rpx 16rpx rgba(4, 50, 44, 0.08);
}

.feedback-chip.active {
  color: #073b35;
  background: linear-gradient(135deg, rgba(191, 255, 0, 0.92), rgba(218, 255, 99, 0.92));
  border-color: rgba(233, 255, 155, 0.92);
}

.strength-section {
  margin-bottom: 10rpx;
}

.track-strength-row {
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(6, 78, 59, 0.12);
}

.preference-done {
  flex: 0 0 auto;
  position: relative;
  z-index: 2;
  width: 320rpx;
  margin: 14rpx auto 0;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 18rpx;
}
