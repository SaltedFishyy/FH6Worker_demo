page {
  min-height: 100vh;
  background: #247c69;
  color: #073b35;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.page {
  padding: 28rpx 28rpx 200rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: linear-gradient(180deg, #2f927a 0%, #247c69 42%, #1c685a 100%);
}

.top-ad {
  display: block;
  margin-bottom: 24rpx;
}

.recommend-entry,
.upgrade-entry {
  min-height: 78rpx;
  margin-bottom: 16rpx;
  padding: 10rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-width: 2rpx;
  border-style: solid;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(4, 62, 55, 0.16);
  -webkit-backdrop-filter: blur(18rpx);
  backdrop-filter: blur(18rpx);
  box-sizing: border-box;
}

.recommend-entry {
  border-color: rgba(191, 255, 0, 0.7);
  background: rgba(248, 255, 251, 0.5);
}

.upgrade-entry {
  border-color: rgba(255, 75, 31, 0.48);
  background: rgba(248, 255, 251, 0.5);
}

.recommend-entry-title,
.upgrade-entry-title {
  color: #064e3b;
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.2;
}

.recommend-entry-subtitle {
  margin-top: 4rpx;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 600;
}

.upgrade-entry-subtitle {
  margin-top: 6rpx;
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 700;
}

.recommend-entry-action,
.upgrade-entry-action {
  flex: 0 0 auto;
  min-width: 188rpx;
  height: 48rpx;
  line-height: 48rpx;
  padding: 0 14rpx;
  border-radius: 12rpx;
  font-size: 23rpx;
  font-weight: 900;
  text-align: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(223, 254, 247, 0.42);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.36), 0 8rpx 18rpx rgba(4, 62, 55, 0.12);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.recommend-entry-action {
  color: #073b35;
  background: rgba(191, 255, 0, 0.76);
}

.upgrade-entry-action {
  color: #ffffff;
  background: rgba(255, 75, 31, 0.72);
  border-color: rgba(255, 188, 166, 0.7);
}

.header {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.brand-title {
  display: inline-flex;
  align-items: center;
  min-width: 430rpx;
  max-width: 100%;
  padding: 12rpx 18rpx 14rpx;
  padding-right: 64rpx;
  border-left: 8rpx solid #bfff00;
  background: linear-gradient(90deg, rgba(4, 47, 43, 0.95) 0%, rgba(5, 83, 74, 0.7) 100%);
  box-shadow: inset 0 -4rpx 0 rgba(191, 255, 0, 0.2), 0 8rpx 18rpx rgba(4, 62, 55, 0.22);
  transform: skewX(-8deg);
}

.brand-fh,
.brand-text,
.model-version {
  display: inline-block;
  line-height: 1;
  font-style: italic;
  font-weight: 900;
  transform: skewX(8deg);
  text-shadow: 0 4rpx 0 rgba(5, 46, 43, 0.42);
}

.brand-fh {
  margin-right: 8rpx;
  color: #bfff00;
  font-size: 48rpx;
  letter-spacing: 0;
}

.brand-text {
  color: #ffffff;
  font-size: 42rpx;
  letter-spacing: 0;
}

.model-version {
  margin-left: 12rpx;
  align-self: flex-end;
  color: rgba(223, 254, 247, 0.82);
  font-size: 25rpx;
  font-weight: 800;
  font-style: normal;
  line-height: 1.05;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.36);
}

.subtitle {
  margin-top: 10rpx;
  color: #eafffb;
  font-size: 26rpx;
  line-height: 1.45;
}

.quota {
  flex: 0 0 210rpx;
  padding: 12rpx 16rpx;
  border: 2rpx solid rgba(191, 255, 0, 0.75);
  border-radius: 8rpx;
  color: #06352f;
  background: rgba(248, 255, 251, 0.48);
  font-size: 22rpx;
  line-height: 1.35;
  text-align: right;
  box-shadow: 0 8rpx 18rpx rgba(4, 93, 82, 0.16);
  -webkit-backdrop-filter: blur(16rpx);
  backdrop-filter: blur(16rpx);
}

.section {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(223, 254, 247, 0.56);
  border-radius: 8rpx;
  background: rgba(248, 255, 251, 0.52);
  box-shadow: 0 10rpx 24rpx rgba(4, 62, 55, 0.18);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.section-title {
  margin-bottom: 18rpx;
  max-width: 100%;
  padding: 10rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 6rpx;
  color: #073b35;
  background: #bfff00;
  font-size: 30rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(135, 214, 0, 0.22);
}

.section-title-icon {
  width: 42rpx;
  height: 42rpx;
  display: block;
}

.field,
.toggle-row {
  display: flex;
  align-items: center;
  min-height: 78rpx;
  gap: 18rpx;
  border-top: 1rpx solid #c7f2e3;
}

.field:first-of-type,
.toggle-row:first-of-type {
  border-top: 0;
}

.switch-control {
  flex: 0 0 70rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.gear-switch {
  transform: scale(0.66);
  transform-origin: right center;
}

.label {
  flex: 0 0 270rpx;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #075e54;
  font-size: 26rpx;
  line-height: 1.35;
  font-weight: 800;
}

.label text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.field-icon {
  flex: 0 0 auto;
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.form-help-icon {
  width: 28rpx;
  height: 28rpx;
  font-size: 20rpx;
  line-height: 28rpx;
}

.input,
.picker {
  flex: 1;
  min-width: 0;
}

.input {
  height: 64rpx;
  color: #062f2b;
  font-size: 26rpx;
  text-align: right;
}

.select-value {
  min-height: 64rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
  color: #062f2b;
  font-size: 26rpx;
}

.two-col {
  padding: 12rpx 0;
}

.two-col .input {
  padding: 0 14rpx;
  border: 1rpx solid #8ee8d4;
  border-radius: 8rpx;
  background: #f8fffc;
  text-align: left;
  box-sizing: border-box;
}

.tire-size-field {
  align-items: center;
}

.tire-size-inputs {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tire-part {
  height: 58rpx;
  padding: 0 8rpx;
  border: 1rpx solid #8ee8d4;
  border-radius: 6rpx;
  color: #062f2b;
  background: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  text-align: center;
}

.tire-width {
  flex: 1.08 1 0;
}

.tire-aspect {
  flex: 0.86 1 0;
}

.tire-rim {
  flex: 0.74 1 0;
}

.tire-fixed {
  flex: 0 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #075e54;
  font-size: 26rpx;
  font-weight: 900;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 26rpx;
}

.primary-button,
.secondary-button {
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(223, 254, 247, 0.4);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.34), 0 10rpx 20rpx rgba(4, 62, 55, 0.14);
  -webkit-backdrop-filter: blur(14rpx);
  backdrop-filter: blur(14rpx);
}

.primary-button {
  flex: 1;
  color: #073b35;
  background: rgba(191, 255, 0, 0.78);
  font-weight: 700;
}

.secondary-button {
  width: 180rpx;
  color: #eafffb;
  background: rgba(223, 254, 247, 0.14);
  border-color: rgba(223, 254, 247, 0.46);
}

.result {
  margin-top: 32rpx;
}

.result-head {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-ad {
  display: block;
  margin: 0 0 20rpx;
}

.edit-tip {
  margin: 0 0 18rpx;
  padding: 18rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  border-radius: 8rpx;
  color: #073b35;
  background: rgba(191, 255, 0, 0.92);
  box-shadow: 0 10rpx 22rpx rgba(4, 62, 55, 0.16);
}

.edit-tip-copy {
  min-width: 0;
  flex: 1;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.35;
}

.edit-tip-action {
  flex: 0 0 auto;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
  color: #eafffb;
  background: rgba(7, 94, 84, 0.62);
  border: 1rpx solid rgba(223, 254, 247, 0.36);
  font-size: 22rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.result-actions {
  margin: 20rpx 0 0;
}

.result-actions-bottom {
  margin-top: 24rpx;
}

.share-link-button {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 14rpx;
  color: #073b35;
  background: rgba(191, 255, 0, 0.78);
  border: 1rpx solid rgba(233, 255, 155, 0.86);
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.38), 0 10rpx 20rpx rgba(135, 214, 0, 0.18);
  -webkit-backdrop-filter: blur(14rpx);
  backdrop-filter: blur(14rpx);
}

.result-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 3rpx 10rpx rgba(3, 77, 67, 0.25);
}

.performance-wrap {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.performance-badge {
  display: flex;
  align-items: stretch;
  min-width: 150rpx;
  height: 58rpx;
  border-radius: 6rpx;
  padding: 4rpx;
  background: #66e600;
  overflow: hidden;
  box-shadow: 0 8rpx 18rpx rgba(4, 62, 55, 0.22);
}

.grade-badge {
  min-width: 58rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 50rpx;
}

.pi-badge {
  min-width: 86rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111111;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 50rpx;
  letter-spacing: 0;
}

.drive-badge {
  height: 58rpx;
  padding: 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
  color: #073b35;
  background: #bfff00;
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(4, 62, 55, 0.18);
}

.grade-D {
  color: #052e3f;
  background: #42c8ff;
}

.grade-wrap-D {
  background: #42c8ff;
}

.grade-C {
  color: #3b2f00;
  background: #ffd400;
}

.grade-wrap-C {
  background: #ffd400;
}

.grade-B {
  color: #ffffff;
  background: #ff8a00;
}

.grade-wrap-B {
  background: #ff8a00;
}

.grade-A {
  color: #ffffff;
  background: #ef233c;
}

.grade-wrap-A {
  background: #ef233c;
}

.grade-S1 {
  color: #ffffff;
  background: #7c3aed;
}

.grade-wrap-S1 {
  background: #7c3aed;
}

.grade-S2 {
  color: #ffffff;
  background: #1d4ed8;
}

.grade-wrap-S2 {
  background: #1d4ed8;
}

.grade-R {
  color: #ffffff;
  background: #d9007f;
}

.grade-wrap-R {
  background: #d9007f;
}

.grade-X {
  color: #073b35;
  background: #66e600;
}

.grade-wrap-X {
  background: #66e600;
}

.result-group {
  margin-top: 18rpx;
  padding: 22rpx;
  border: 0;
  border-radius: 8rpx;
  background: rgba(248, 255, 251, 0.52);
  border: 1rpx solid rgba(223, 254, 247, 0.5);
  box-shadow: 0 10rpx 24rpx rgba(4, 62, 55, 0.16);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.group-title {
  margin-bottom: 8rpx;
  color: #064e3b;
  font-size: 28rpx;
  font-weight: 700;
}

.result-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 64rpx;
  align-items: center;
  border-top: 1rpx solid #c7f2e3;
}

.result-row:first-of-type {
  border-top: 0;
}

.result-label {
  color: #075e54;
  font-size: 25rpx;
}

.result-label-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.help-icon {
  flex: 0 0 auto;
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #073b35;
  background: rgba(191, 255, 0, 0.76);
  border: 1rpx solid rgba(233, 255, 155, 0.9);
  font-size: 21rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.38), 0 4rpx 10rpx rgba(4, 62, 55, 0.12);
  -webkit-backdrop-filter: blur(10rpx);
  backdrop-filter: blur(10rpx);
}

.edited-badge {
  flex: 0 0 auto;
  padding: 3rpx 8rpx;
  border-radius: 6rpx;
  color: #075e54;
  background: #dffef7;
  font-size: 20rpx;
  font-weight: 800;
}

.result-value {
  flex: 0 0 auto;
  min-width: 150rpx;
  color: #052e2b;
  font-size: 28rpx;
  font-weight: 700;
  text-align: right;
}

.edit-input {
  width: 170rpx;
  height: 54rpx;
  padding: 0 12rpx;
  border: 2rpx solid #0fae96;
  border-radius: 6rpx;
  color: #052e2b;
  background: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  text-align: right;
  box-sizing: border-box;
}

.unit {
  color: #0f766e;
  font-size: 22rpx;
  font-weight: 400;
}

.plain-note {
  margin-top: 6rpx;
  color: #075e54;
  font-size: 24rpx;
  line-height: 1.5;
}

.loading-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: rgba(6, 95, 84, 0.82);
}

.tire-spinner {
  width: 136rpx;
  height: 136rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  filter: drop-shadow(0 12rpx 22rpx rgba(5, 46, 43, 0.28));
  animation: tire-roll 0.72s linear infinite;
}

.tire-image {
  width: 136rpx;
  height: 136rpx;
  display: block;
}

.loading-text {
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  text-shadow: 0 3rpx 10rpx rgba(3, 77, 67, 0.25);
}

.preference-fab {
  position: fixed;
  left: 50%;
  bottom: 132rpx;
  z-index: 70;
  width: 128rpx;
  height: 128rpx;
  margin-left: -64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #073b35;
  background: rgba(191, 255, 0, 0.78);
  border: 1rpx solid rgba(233, 255, 155, 0.86);
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.34), 0 14rpx 34rpx rgba(4, 86, 75, 0.34);
  -webkit-backdrop-filter: blur(14rpx);
  backdrop-filter: blur(14rpx);
}

.preference-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1200;
  display: flex;
  align-items: flex-end;
  background: rgba(5, 46, 43, 0.48);
}

.preference-panel {
  width: 100%;
  padding: 30rpx 30rpx calc(42rpx + env(safe-area-inset-bottom));
  border-radius: 24rpx 24rpx 0 0;
  background: rgba(248, 255, 251, 0.72);
  border-top: 8rpx solid #bfff00;
  -webkit-backdrop-filter: blur(28rpx);
  backdrop-filter: blur(28rpx);
}

.preference-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #064e3b;
}

.preference-row {
  margin-top: 28rpx;
}

.preference-label {
  margin-bottom: 6rpx;
  color: #075e54;
  font-size: 26rpx;
  font-weight: 700;
}

.scale-row {
  display: flex;
  justify-content: space-between;
  margin-top: -6rpx;
  color: #0f766e;
  font-size: 22rpx;
}

.preference-done {
  margin-top: 30rpx;
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 14rpx;
  color: #073b35;
  background: rgba(191, 255, 0, 0.78);
  border: 1rpx solid rgba(233, 255, 155, 0.86);
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.38), 0 10rpx 20rpx rgba(135, 214, 0, 0.18);
  -webkit-backdrop-filter: blur(14rpx);
  backdrop-filter: blur(14rpx);
}

@keyframes tire-roll {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* Glass neon visual refresh */
.page {
  background: #062f2b;
}

.recommend-entry,
.upgrade-entry {
  border-width: 1rpx;
  border-radius: 12rpx;
  background: rgba(223, 254, 247, 0.58);
  border-color: rgba(223, 254, 247, 0.64);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.52),
    0 8rpx 22rpx rgba(3, 33, 30, 0.18);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.recommend-entry {
  border-color: rgba(191, 255, 0, 0.58);
}

.upgrade-entry {
  border-color: rgba(255, 142, 112, 0.5);
}

.header {
  margin-top: 6rpx;
}

.quota {
  border-width: 1rpx;
  border-color: rgba(191, 255, 0, 0.64);
  border-radius: 14rpx;
  background: rgba(223, 254, 247, 0.5);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
    0 8rpx 22rpx rgba(3, 33, 30, 0.14);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.section {
  position: relative;
  overflow: hidden;
  padding: 18rpx 22rpx 20rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(223, 254, 247, 0.72);
  background:
    linear-gradient(135deg, rgba(235, 255, 249, 0.72) 0%, rgba(207, 243, 233, 0.48) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.62),
    inset 0 0 28rpx rgba(255, 255, 255, 0.16),
    0 12rpx 26rpx rgba(3, 33, 30, 0.22),
    0 0 0 1rpx rgba(191, 255, 0, 0.08);
  -webkit-backdrop-filter: blur(30rpx);
  backdrop-filter: blur(30rpx);
}

.section::after {
  content: "";
  position: absolute;
  right: 18rpx;
  top: 16rpx;
  width: 76rpx;
  height: 10rpx;
  opacity: 0.58;
  background: repeating-linear-gradient(
    135deg,
    rgba(191, 255, 0, 0.86) 0,
    rgba(191, 255, 0, 0.86) 8rpx,
    transparent 8rpx,
    transparent 14rpx
  );
}

.section-title {
  position: relative;
  margin-bottom: 12rpx;
  padding: 8rpx 0 12rpx 22rpx;
  border-radius: 0;
  color: #073b35;
  background: transparent;
  box-shadow: none;
  font-size: 30rpx;
  line-height: 1.2;
}

.section-title::before {
  content: "";
  position: absolute;
  left: 0;
  top: 4rpx;
  bottom: 10rpx;
  width: 7rpx;
  border-radius: 999rpx;
  background: #bfff00;
