}

.class-tab-B.class-tab-active {
  color: #ffffff;
  background: rgba(255, 138, 0, 0.86);
  border-color: rgba(255, 205, 135, 0.95);
}

.class-tab-A.class-tab-active {
  color: #ffffff;
  background: rgba(239, 35, 60, 0.86);
