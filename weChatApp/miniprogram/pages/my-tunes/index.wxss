page {
  min-height: 100vh;
  background: #247c69;
  color: #073b35;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.my-page {
  min-height: 100vh;
  padding: 28rpx 28rpx 200rpx;
  background: linear-gradient(180deg, #2f927a 0%, #247c69 44%, #1c685a 100%);
  box-sizing: border-box;
}

.hero {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.brand-title {
  display: inline-flex;
  align-items: center;
  min-width: 430rpx;
  max-width: 100%;
  padding: 12rpx 18rpx 14rpx;
  padding-right: 64rpx;
  border-left: 8rpx solid #bfff00;
  background: linear-gradient(90deg, rgba(4, 47, 43, 0.95) 0%, rgba(5, 83, 74, 0.7) 100%);
  box-shadow: inset 0 -4rpx 0 rgba(191, 255, 0, 0.2), 0 8rpx 18rpx rgba(4, 62, 55, 0.22);
  transform: skewX(-8deg);
}

.brand-fh,
.brand-text {
  display: inline-block;
  line-height: 1;
  font-style: italic;
  font-weight: 900;
  transform: skewX(8deg);
  text-shadow: 0 4rpx 0 rgba(5, 46, 43, 0.42);
}

.brand-fh {
  margin-right: 8rpx;
  color: #bfff00;
  font-size: 48rpx;
  letter-spacing: 0;
}

.brand-text {
  color: #ffffff;
  font-size: 42rpx;
  letter-spacing: 0;
}

.local-note {
  margin-top: 12rpx;
  color: #dffef7;
  font-size: 23rpx;
  line-height: 1.4;
}

.count-pill {
  flex: 0 0 auto;
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  color: #073b35;
  background: rgba(191, 255, 0, 0.76);
  border: 1rpx solid rgba(233, 255, 155, 0.86);
  font-size: 24rpx;
  font-weight: 900;
  box-shadow: 0 8rpx 18rpx rgba(4, 62, 55, 0.18);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.toolbar-title {
  color: #eafffb;
  font-size: 28rpx;
  font-weight: 900;
}

.clear-button {
  padding: 10rpx 16rpx;
  border-radius: 12rpx;
  color: #eafffb;
  background: rgba(223, 254, 247, 0.14);
  border: 1rpx solid rgba(223, 254, 247, 0.42);
  font-size: 23rpx;
  font-weight: 800;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.24), 0 8rpx 18rpx rgba(4, 62, 55, 0.12);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.empty-state {
  padding: 32rpx 24rpx;
  border-radius: 8rpx;
  background: rgba(248, 255, 251, 0.52);
  border: 1rpx solid rgba(223, 254, 247, 0.5);
  box-shadow: 0 10rpx 24rpx rgba(4, 62, 55, 0.16);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.empty-title {
  color: #064e3b;
  font-size: 30rpx;
  font-weight: 900;
}

.empty-copy {
  margin-top: 10rpx;
  color: #0f766e;
  font-size: 24rpx;
  line-height: 1.45;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.record-card {
  padding: 20rpx;
  border-radius: 8rpx;
  background: rgba(248, 255, 251, 0.52);
  border: 1rpx solid rgba(223, 254, 247, 0.5);
  box-shadow: 0 10rpx 24rpx rgba(4, 62, 55, 0.18);
  -webkit-backdrop-filter: blur(26rpx);
  backdrop-filter: blur(26rpx);
}

.record-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
}

.record-copy {
  min-width: 0;
  flex: 1;
}

.record-title-row {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.record-title {
  min-width: 0;
  flex: 1;
  color: #052e2b;
  font-size: 30rpx;
  line-height: 1.25;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rename-button {
  flex: 0 0 auto;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  color: #073b35;
  background: rgba(191, 255, 0, 0.82);
  border: 1rpx solid rgba(233, 255, 155, 0.82);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 1.2;
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.36),
    0 6rpx 14rpx rgba(111, 199, 0, 0.14);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.record-meta {
  margin-top: 8rpx;
  color: #0f766e;
  font-size: 23rpx;
  font-weight: 700;
}

.performance-badge {
  flex: 0 0 auto;
  display: flex;
  align-items: stretch;
  min-width: 148rpx;
  height: 56rpx;
  border-radius: 6rpx;
  padding: 4rpx;
  background: #66e600;
  overflow: hidden;
  box-shadow: 0 8rpx 18rpx rgba(4, 62, 55, 0.2);
}

.grade-badge {
  min-width: 56rpx;
  padding: 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 48rpx;
}

.pi-badge {
  min-width: 84rpx;
  padding: 0 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  background: #111111;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 48rpx;
  letter-spacing: 0;
}

.grade-D,
.grade-wrap-D {
  color: #052e3f;
  background: #42c8ff;
}

.grade-C,
.grade-wrap-C {
  color: #3b2f00;
  background: #ffd400;
}

.grade-B,
.grade-wrap-B {
  color: #ffffff;
  background: #ff8a00;
}

.grade-A,
.grade-wrap-A {
  color: #ffffff;
  background: #ef233c;
}

.grade-S1,
.grade-wrap-S1 {
  color: #ffffff;
  background: #7c3aed;
}

.grade-S2,
.grade-wrap-S2 {
  color: #ffffff;
  background: #1d4ed8;
}

.grade-R,
.grade-wrap-R {
  color: #ffffff;
  background: #d9007f;
}

.grade-X,
.grade-wrap-X {
  color: #073b35;
  background: #66e600;
}

.record-detail {
  margin-top: 18rpx;
}

.detail-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.share-record-button,
.delete-button {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 800;
  border: 1rpx solid rgba(223, 254, 247, 0.42);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.28), 0 8rpx 18rpx rgba(4, 62, 55, 0.12);
  -webkit-backdrop-filter: blur(12rpx);
  backdrop-filter: blur(12rpx);
}

.share-record-button {
  color: #073b35;
  background: rgba(191, 255, 0, 0.76);
  border-color: rgba(233, 255, 155, 0.86);
}

.share-record-native {
  margin: 0;
  line-height: 1.2;
}

.share-record-native::after {
  border: 0;
}

.delete-button {
  color: #ffffff;
  background: rgba(239, 35, 60, 0.72);
  border-color: rgba(255, 160, 170, 0.86);
}

.result-group {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  background: rgba(223, 254, 247, 0.46);
  border: 1rpx solid rgba(223, 254, 247, 0.42);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.group-title {
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid rgba(7, 94, 84, 0.14);
  color: #06352f;
  font-size: 28rpx;
  font-weight: 900;
}

.result-row {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 12rpx 0;
  border-bottom: 2rpx solid rgba(7, 94, 84, 0.1);
}

.result-row:last-child {
  border-bottom: 0;
}

.result-label {
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 700;
}

.result-label-wrap {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.help-icon {
  flex: 0 0 auto;
  width: 30rpx;
  height: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #073b35;
  background: rgba(191, 255, 0, 0.76);
  border: 1rpx solid rgba(233, 255, 155, 0.9);
  font-size: 21rpx;
  font-weight: 900;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.38), 0 4rpx 10rpx rgba(4, 62, 55, 0.12);
  -webkit-backdrop-filter: blur(10rpx);
  backdrop-filter: blur(10rpx);
}

.edited-badge {
  flex: 0 0 auto;
  padding: 3rpx 8rpx;
  border-radius: 6rpx;
  color: #075e54;
  background: rgba(255, 255, 255, 0.82);
  font-size: 20rpx;
  font-weight: 800;
}

.result-value {
  flex: 0 0 auto;
  min-width: 150rpx;
  color: #052e2b;
  font-size: 25rpx;
  font-weight: 900;
  text-align: right;
}

.edit-input {
  width: 170rpx;
  height: 52rpx;
  padding: 0 12rpx;
  border: 2rpx solid #0fae96;
  border-radius: 6rpx;
  color: #052e2b;
  background: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  text-align: right;
  box-sizing: border-box;
}

.unit {
  margin-left: 4rpx;
  color: #0f766e;
  font-size: 20rpx;
  font-weight: 700;
}

.plain-note {
  padding: 12rpx 0 0;
  color: #075e54;
  font-size: 24rpx;
  line-height: 1.45;
}

/* Glass neon visual refresh */
.my-page {
  background: #062f2b;
}

.count-pill {
  border-radius: 14rpx;
  background: rgba(191, 255, 0, 0.82);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.45),
    0 8rpx 18rpx rgba(4, 62, 55, 0.18),
    0 0 16rpx rgba(191, 255, 0, 0.18);
}

.clear-button {
  color: #073b35;
  background: rgba(191, 255, 0, 0.82);
  border-color: rgba(233, 255, 155, 0.88);
}

.empty-state,
.record-card {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid rgba(191, 255, 0, 0.26);
  background:
    linear-gradient(135deg, rgba(11, 79, 70, 0.68) 0%, rgba(4, 36, 34, 0.78) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(223, 254, 247, 0.18),
    0 0 0 1rpx rgba(223, 254, 247, 0.07),
    0 12rpx 28rpx rgba(0, 0, 0, 0.24),
    0 0 18rpx rgba(191, 255, 0, 0.11);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.record-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 14rpx;
  bottom: 14rpx;
  width: 3rpx;
  background: rgba(191, 255, 0, 0.84);
  box-shadow: 0 0 16rpx rgba(191, 255, 0, 0.78);
}

.empty-title,
.record-title {
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.32);
}

.empty-copy,
.record-meta {
  color: rgba(223, 254, 247, 0.82);
}

.detail-actions {
  margin-top: 4rpx;
}

.share-record-button {
  color: #073b35;
  background: rgba(191, 255, 0, 0.86);
  border-color: rgba(233, 255, 155, 0.9);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.42),
    0 8rpx 18rpx rgba(111, 199, 0, 0.18),
    0 0 14rpx rgba(191, 255, 0, 0.16);
}

.delete-button {
  color: #ffffff;
  background: rgba(239, 35, 60, 0.78);
  border-color: rgba(255, 160, 170, 0.82);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.24),
    0 8rpx 18rpx rgba(99, 10, 26, 0.2);
}

.result-group {
  position: relative;
  overflow: hidden;
  border-radius: 14rpx;
  border: 1rpx solid rgba(191, 255, 0, 0.24);
  background:
    linear-gradient(135deg, rgba(11, 79, 70, 0.62) 0%, rgba(3, 32, 30, 0.72) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(223, 254, 247, 0.16),
    inset 0 0 28rpx rgba(191, 255, 0, 0.04),
    0 8rpx 18rpx rgba(0, 0, 0, 0.18);
  -webkit-backdrop-filter: blur(22rpx);
  backdrop-filter: blur(22rpx);
}

.group-title {
  color: #eafffb;
  border-bottom-color: rgba(223, 254, 247, 0.14);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.result-row {
  min-height: 66rpx;
  padding: 13rpx 16rpx;
  border-bottom: 1rpx solid rgba(223, 254, 247, 0.11);
  background: rgba(2, 30, 28, 0.22);
}

.result-label {
  color: rgba(234, 255, 251, 0.88);
}

.result-value {
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.34);
}

.unit {
  color: rgba(223, 254, 247, 0.68);
}

.plain-note {
  color: rgba(223, 254, 247, 0.86);
}

.help-icon {
  color: #073b35;
  background: rgba(191, 255, 0, 0.9);
  border-color: rgba(233, 255, 155, 0.95);
  box-shadow:
    inset 0 1rpx 0 rgba(255, 255, 255, 0.46),
    0 0 12rpx rgba(191, 255, 0, 0.4);
}

.edited-badge {
  color: #073b35;
  background: rgba(191, 255, 0, 0.72);
  border: 1rpx solid rgba(233, 255, 155, 0.66);
}

.edit-input {
  color: #ffffff;
  background: rgba(2, 30, 28, 0.72);
  border-color: rgba(191, 255, 0, 0.62);
}

/* Final unified card pass: match quick tune cards */
.empty-state,
.record-card,
.result-group {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid rgba(191, 255, 0, 0.32);
  background:
    linear-gradient(135deg, rgba(11, 79, 70, 0.7) 0%, rgba(4, 36, 34, 0.82) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(223, 254, 247, 0.18),
    inset 0 0 34rpx rgba(191, 255, 0, 0.05),
    0 0 0 1rpx rgba(223, 254, 247, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.24),
    0 0 20rpx rgba(191, 255, 0, 0.12);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.empty-state::before,
.record-card::before,
.result-group::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16rpx;
  bottom: 16rpx;
  width: 3rpx;
  background: rgba(191, 255, 0, 0.84);
  box-shadow: 0 0 16rpx rgba(191, 255, 0, 0.8);
}

.empty-state::after,
.record-card::after,
.result-group::after {
  content: "";
  position: absolute;
  right: 18rpx;
  top: 16rpx;
  width: 76rpx;
  height: 10rpx;
  opacity: 0.46;
  background: repeating-linear-gradient(
    135deg,
    rgba(191, 255, 0, 0.86) 0,
    rgba(191, 255, 0, 0.86) 8rpx,
    transparent 8rpx,
    transparent 14rpx
  );
}

.record-head,
.record-detail,
.empty-title,
.empty-copy,
.result-group .group-title,
.result-group .result-row,
.result-group .plain-note {
  position: relative;
  z-index: 1;
}

.record-title,
.empty-title,
.group-title {
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.32);
}

.record-meta,
.empty-copy {
  color: rgba(223, 254, 247, 0.84);
}
