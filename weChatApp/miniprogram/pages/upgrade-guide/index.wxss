/* Unified dark card style */
.guide-entry,
.objective-card,
.priority-card,
.bottom-note {
  border-radius: 16rpx;
  border: 1rpx solid rgba(191, 255, 0, 0.32);
  background:
    linear-gradient(135deg, rgba(11, 79, 70, 0.7) 0%, rgba(4, 36, 34, 0.82) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(223, 254, 247, 0.18),
    inset 0 0 34rpx rgba(191, 255, 0, 0.05),
    0 0 0 1rpx rgba(223, 254, 247, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.24),
    0 0 20rpx rgba(191, 255, 0, 0.12);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.guide-entry::before,
.objective-card::before,
.priority-card::before,
.bottom-note::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16rpx;
  bottom: 16rpx;
  width: 3rpx;
  background: rgba(191, 255, 0, 0.84);
  box-shadow: 0 0 16rpx rgba(191, 255, 0, 0.8);
}

.guide-entry::after,
.objective-card::after {
  opacity: 0.46;
}

.entry-title,
.objective-title,
.upgrade-name,
.note-title {
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.32);
}

.entry-copy,
.line-copy,
.upgrade-note,
.note-copy {
  color: rgba(223, 254, 247, 0.84);
}

.objective-kicker {
  color: rgba(191, 255, 0, 0.9);
}

.objective-line,
.upgrade-row {
  border-top-color: rgba(223, 254, 247, 0.12);
}

.line-label {
  color: #bfff00;
}

.priority-title {
  border-bottom: 1rpx solid rgba(223, 254, 247, 0.12);
}

/* Final unified card pass: match quick tune cards */
.guide-entry,
.objective-card,
.priority-card,
.bottom-note {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  border: 1rpx solid rgba(191, 255, 0, 0.32);
  background:
    linear-gradient(135deg, rgba(11, 79, 70, 0.7) 0%, rgba(4, 36, 34, 0.82) 100%);
  box-shadow:
    inset 0 1rpx 0 rgba(223, 254, 247, 0.18),
    inset 0 0 34rpx rgba(191, 255, 0, 0.05),
    0 0 0 1rpx rgba(223, 254, 247, 0.08),
    0 10rpx 24rpx rgba(0, 0, 0, 0.24),
    0 0 20rpx rgba(191, 255, 0, 0.12);
  -webkit-backdrop-filter: blur(24rpx);
  backdrop-filter: blur(24rpx);
}

.guide-entry::before,
.objective-card::before,
.priority-card::before,
.bottom-note::before {
  content: "";
  position: absolute;
  left: 0;
  top: 16rpx;
  bottom: 16rpx;
  width: 3rpx;
  background: rgba(191, 255, 0, 0.84);
  box-shadow: 0 0 16rpx rgba(191, 255, 0, 0.8);
}

.guide-entry::after,
.objective-card::after,
.priority-card::after,
.bottom-note::after {
  content: "";
  position: absolute;
  right: 18rpx;
  top: 16rpx;
  width: 76rpx;
  height: 10rpx;
  opacity: 0.46;
  background: repeating-linear-gradient(
    135deg,
    rgba(191, 255, 0, 0.86) 0,
    rgba(191, 255, 0, 0.86) 8rpx,
    transparent 8rpx,
    transparent 14rpx
  );
}

.guide-entry > view,
.objective-card > view,
.priority-card > view,
.bottom-note > view,
.priority-card block,
.upgrade-row {
  position: relative;
  z-index: 1;
}

.entry-title,
.objective-title,
.upgrade-name,
.note-title {
  color: #ffffff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.32);
}

.entry-copy,
.line-copy,
.upgrade-note,
.note-copy {
  color: rgba(223, 254, 247, 0.84);
}

.objective-line,
.upgrade-row {
  border-top-color: rgba(223, 254, 247, 0.12);
}

.priority-title {
  color: #ffffff;
  background:
    linear-gradient(90deg, rgba(239, 79, 47, 0.88) 0%, rgba(11, 79, 70, 0.68) 100%);
  border-bottom: 1rpx solid rgba(223, 254, 247, 0.12);
}

.priority-p1 .priority-title,
.priority-p2 .priority-title,
.priority-p3 .priority-title {
  background:
    linear-gradient(90deg, rgba(15, 174, 150, 0.72) 0%, rgba(11, 79, 70, 0.68) 100%);
}

.priority-avoid .priority-title {
  background:
    linear-gradient(90deg, rgba(17, 17, 17, 0.86) 0%, rgba(11, 79, 70, 0.68) 100%);
}

/* Remove the hard divider on the fixed shortcut bar. */
.shortcut-row {
  overflow: visible;
  background:
    linear-gradient(180deg, rgba(4, 54, 49, 0) 0%, rgba(4, 54, 49, 0.5) 32%, rgba(4, 54, 49, 0.74) 100%);
  border-top: 0 !important;
  box-shadow: none !important;
}

.shortcut-row::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: -28rpx;
  height: 28rpx;
  background: linear-gradient(180deg, rgba(4, 54, 49, 0) 0%, rgba(4, 54, 49, 0.5) 100%);
  pointer-events: none;
}
